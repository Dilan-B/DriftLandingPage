# Next.js Environment Variables

# Email Service (SendGrid)
# SENDGRID_API_KEY=your_sendgrid_api_key_here
# SENDGRID_FROM_EMAIL=noreply@joindrift.app

# Contact Form
# CONTACT_EMAIL=driftappcontact@gmail.com

# Waitlist Google Sheet
# Create/share a Google Sheet with the service account email below.
# GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
# GOOGLE_SHEETS_WAITLIST_TAB=Waitlist
# GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# App Store Links (Update with actual URLs)
# NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/...
# NEXT_PUBLIC_PLAY_STORE_URL=https://play.google.com/...
